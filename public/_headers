/*
  Static security headers. Honored by Netlify, Vercel, Cloudflare Pages,
  and other hosts that read a top-level `_headers` file. Vite dev applies
  a similar (but looser) set via `server.headers` in vite.config.ts.

  The CSP allows:
    - self for app code/styles
    - Supabase project domain (REST, Realtime WebSockets, Storage, Functions)
    - api.pwnedpasswords.com for the HIBP breach check
    - Google Fonts (fonts.googleapis.com / fonts.gstatic.com)
    - data: and blob: for inline images / generated previews
*/
/*
  Path:* matches every route.
*/
/*
  Note: 'unsafe-inline' on style-src is required by Tailwind/Radix runtime
  styles. 'unsafe-eval' on script-src is intentionally omitted in prod.
*/

/*
*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; media-src 'self' blob:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.pwnedpasswords.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; worker-src 'self' blob:
